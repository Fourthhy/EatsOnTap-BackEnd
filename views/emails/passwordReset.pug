doctype html
html
  head
    meta(name='viewport', content='width=device-width')
    meta(http-equiv='Content-Type', content='text/html; charset=UTF-8')
    style.
      body { font-family: sans-serif; background-color: #f6f6f6; padding: 20px; }
      .container { background-color: #ffffff; padding: 30px; border-radius: 8px; max-width: 600px; margin: 0 auto; }
      .btn { background-color: #ef4444; color: white; padding: 12px 24px; text-decoration: none; border-radius: 5px; display: inline-block; margin: 20px 0; font-weight: bold; }
  body
    .container
      h2 Reset Your Password
      p Hi #{firstName},
      p Your password reset request has been approved. Your password has been reset to the default.
      a.btn(href=url) Reset Password
      p If this is not from you, ignore this email.